{
  "name": "atomic-query",
  "version": "3.0.1",
  "description": "Biblioteca de requisições funcional e performática",
  "keywords": [
    "http",
    "fetch",
    "requests",
    "typescript",
    "middleware",
    "security",
    "zero-dependency",
    "streaming"
  ],
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/react": "^19.2.14",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "rollup": "^4.60.2",
    "rollup-plugin-dts": "^6.4.1",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
